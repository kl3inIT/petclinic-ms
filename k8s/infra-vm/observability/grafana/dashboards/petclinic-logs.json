{
  "title": "PetClinic — Logs",
  "uid": "petclinic-logs",
  "tags": ["petclinic", "logs"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "app",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": { "label": "app", "stream": "" },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "type": "logs",
      "title": "Logs — $app",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 18, "w": 24, "x": 0, "y": 0 },
      "options": { "showTime": true, "wrapLogMessage": true, "dedupStrategy": "none", "enableLogDetails": true },
      "targets": [
        { "refId": "A", "datasource": { "type": "loki", "uid": "loki" }, "expr": "{namespace=\"petclinic\", app=~\"$app\"}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Log volume by app",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 18 },
      "targets": [
        { "refId": "A", "datasource": { "type": "loki", "uid": "loki" }, "expr": "sum by (app) (count_over_time({namespace=\"petclinic\", app=~\"$app\"}[5m]))" }
      ]
    }
  ]
}
