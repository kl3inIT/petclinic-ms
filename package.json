{
  "name": "petclinic-ms",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "web:dev": "pnpm --filter @petclinic/web dev",
    "web:build": "pnpm --filter @petclinic/web build",
    "web:lint": "pnpm --filter @petclinic/web lint",
    "web:typecheck": "pnpm --filter @petclinic/web typecheck",
    "web:test": "pnpm --filter @petclinic/web test",
    "web:generate:api": "pnpm --filter @petclinic/web generate:api",
    "format": "prettier --write \"{apps,packages}/**/*.{ts,tsx,json,md,css}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "apps/web/**/*.{ts,tsx,js,jsx}": [
      "pnpm --filter @petclinic/web exec eslint --max-warnings 0 --no-warn-ignored --fix",
      "prettier --write"
    ],
    "apps/web/**/*.{json,css,md}": [
      "prettier --write"
    ],
    "{apps,packages}/**/*.{ts,tsx,json,css,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.10.5"
  }
}
