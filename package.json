{
  "name": "petclinic-ms",
  "private": true,
  "packageManager": "pnpm@11.0.8",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": "11.0.8"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "web:dev": "pnpm --filter @petclinic/web dev",
    "web:build": "pnpm --filter @petclinic/web build",
    "web:lint": "pnpm --filter @petclinic/web lint",
    "web:typecheck": "pnpm --filter @petclinic/web typecheck",
    "web:test": "pnpm --filter @petclinic/web test",
    "web:generate:api": "pnpm --filter @petclinic/web generate:api",
    "format": "prettier --write \"{apps,packages}/**/*.{ts,tsx,json,md,css}\""
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "turbo": "^2.9.14"
  },
  "pnpm": {
    "overrides": {
      "vite": "^8.0.0"
    }
  }
}
