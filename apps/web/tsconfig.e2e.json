{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "verbatimModuleSyntax": true,
    "types": ["node"],
    "paths": { "@/*": ["./src/*"] }
  },
  "include": ["e2e/**/*", "playwright.config.ts"]
}
