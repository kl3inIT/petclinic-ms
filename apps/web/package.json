{
  "name": "@petclinic/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "routes:generate": "tsr generate",
    "routes:watch": "tsr watch",
    "dev": "vite --host --port 3333",
    "build": "tsr generate && tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsr generate && tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "fetch:openapi": "tsx scripts/fetch-openapi.ts",
    "generate:api": "orval --config orval.config.ts"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "@tanstack/react-router": "^1.167.0",
    "@tanstack/react-query": "^5.90.3",
    "@tanstack/react-query-devtools": "^5.90.3",
    "@tanstack/react-table": "^8.21.2",
    "axios": "^1.7.9",
    "react-hook-form": "^7.54.2",
    "zod": "^3.24.1",
    "@hookform/resolvers": "^3.10.0",
    "zustand": "^5.0.3",
    "sonner": "^2.0.1",
    "lucide-react": "^0.474.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0",
    "class-variance-authority": "^0.7.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@types/node": "^22.10.7",
    "@vitejs/plugin-react-swc": "^4.0.0",
    "vite": "^8.0.0",
    "typescript": "^5.8.2",
    "@tanstack/router-plugin": "^1.167.0",
    "@tanstack/router-devtools": "^1.167.0",
    "@tanstack/router-cli": "^1.167.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "postcss": "^8.5.1",
    "autoprefixer": "^10.4.20",
    "orval": "^7.4.1",
    "tsx": "^4.19.2",
    "eslint": "^9.18.0",
    "@eslint/js": "^9.18.0",
    "typescript-eslint": "^8.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0",
    "vitest": "^3.2.0",
    "@vitest/ui": "^3.2.0",
    "jsdom": "^25.0.1",
    "@testing-library/react": "^16.1.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@playwright/test": "^1.50.0"
  }
}
