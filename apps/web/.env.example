# Axios base URL — bỏ trống vì orval-generated URL đã chứa /api prefix.
# Vite dev proxy /api → gateway:8180 (xem vite.config.ts).
# Production: trỏ thẳng ingress nếu deploy khác origin, vd https://api.petclinic.example.com
VITE_API_BASE_URL=

# OpenAPI aggregator endpoint trên gateway (springdoc.swagger-ui.urls list 4 service)
GATEWAY_URL=http://localhost:8180
