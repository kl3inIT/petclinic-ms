<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
                  id="Definitions_VisitBooking"
                  targetNamespace="http://mss301.petclinic/workflow">

  <bpmn:process id="visit-booking" name="Visit Booking" isExecutable="true">

    <!-- Bắt đầu: visits-service gọi startProcess() sau khi lưu Visit (SCHEDULED) -->
    <bpmn:startEvent id="StartEvent_VisitBooked" name="Lịch hẹn đã đặt">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- Bác sĩ xác nhận bắt đầu khám — complete task này qua Task Inbox UI -->
    <bpmn:userTask id="UserTask_StartVisit" name="Bắt đầu khám">
      <bpmn:extensionElements>
        <zeebe:userTask/>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Service task: callback về visits-service để chuyển SCHEDULED → IN_PROGRESS -->
    <bpmn:serviceTask id="ServiceTask_MarkInProgress" name="Chuyển sang IN_PROGRESS">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="petclinic:visit:transition"/>
        <zeebe:ioMapping>
          <zeebe:input source="= visitId" target="visitId"/>
          <zeebe:input source="= &quot;IN_PROGRESS&quot;" target="targetStatus"/>
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Bác sĩ hoàn thành khám — nhập diagnosis, treatment, fee khi complete task -->
    <bpmn:userTask id="UserTask_CompleteVisit" name="Hoàn thành khám">
      <bpmn:extensionElements>
        <zeebe:userTask/>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Service task: callback về visits-service để chuyển IN_PROGRESS → COMPLETED -->
    <bpmn:serviceTask id="ServiceTask_MarkCompleted" name="Chuyển sang COMPLETED">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="petclinic:visit:transition"/>
        <zeebe:ioMapping>
          <zeebe:input source="= visitId" target="visitId"/>
          <zeebe:input source="= &quot;COMPLETED&quot;" target="targetStatus"/>
          <zeebe:input source="= diagnosis" target="diagnosis"/>
          <zeebe:input source="= treatment" target="treatment"/>
          <zeebe:input source="= fee" target="fee"/>
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="EndEvent_Done" name="Hoàn tất">
      <bpmn:incoming>Flow_5</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_VisitBooked" targetRef="UserTask_StartVisit"/>
    <bpmn:sequenceFlow id="Flow_2" sourceRef="UserTask_StartVisit" targetRef="ServiceTask_MarkInProgress"/>
    <bpmn:sequenceFlow id="Flow_3" sourceRef="ServiceTask_MarkInProgress" targetRef="UserTask_CompleteVisit"/>
    <bpmn:sequenceFlow id="Flow_4" sourceRef="UserTask_CompleteVisit" targetRef="ServiceTask_MarkCompleted"/>
    <bpmn:sequenceFlow id="Flow_5" sourceRef="ServiceTask_MarkCompleted" targetRef="EndEvent_Done"/>

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_VisitBooking">
    <bpmndi:BPMNPlane id="BPMNPlane_VisitBooking" bpmnElement="visit-booking">
      <bpmndi:BPMNShape id="StartEvent_VisitBooked_di" bpmnElement="StartEvent_VisitBooked">
        <dc:Bounds x="152" y="202" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="130" y="245" width="82" height="27"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="UserTask_StartVisit_di" bpmnElement="UserTask_StartVisit">
        <dc:Bounds x="250" y="180" width="100" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ServiceTask_MarkInProgress_di" bpmnElement="ServiceTask_MarkInProgress">
        <dc:Bounds x="420" y="180" width="100" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="UserTask_CompleteVisit_di" bpmnElement="UserTask_CompleteVisit">
        <dc:Bounds x="590" y="180" width="100" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ServiceTask_MarkCompleted_di" bpmnElement="ServiceTask_MarkCompleted">
        <dc:Bounds x="760" y="180" width="100" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Done_di" bpmnElement="EndEvent_Done">
        <dc:Bounds x="932" y="202" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="930" y="245" width="42" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="188" y="220"/>
        <di:waypoint x="250" y="220"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="350" y="220"/>
        <di:waypoint x="420" y="220"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="520" y="220"/>
        <di:waypoint x="590" y="220"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="690" y="220"/>
        <di:waypoint x="760" y="220"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="860" y="220"/>
        <di:waypoint x="932" y="220"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>
