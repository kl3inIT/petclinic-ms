<?xml version="1.0" encoding="UTF-8"?>
  <bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" 
                    xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"  
                    xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"        
                    xmlns:di="http://www.omg.org/spec/DD/20100524/DI"        
                    xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"        
                    id="Defs_Parent"
  targetNamespace="http://bpmn.io/schema/bpmn">
    <bpmn:process id="dat-lich-kham-thu-cung" name="Đặt lịch khám thú cưng"  
  isExecutable="true">

      <bpmn:startEvent id="Start_1" name="Người dùng đặt lịch khám">
        <bpmn:outgoing>F1</bpmn:outgoing>
      </bpmn:startEvent>

      <bpmn:userTask id="Task_TiepNhan" name="Lễ tân kiểm tra chuyên môn bác 
  sĩ">
        <bpmn:extensionElements>
          <zeebe:assignmentDefinition assignee="receptionist" />
        </bpmn:extensionElements>
        <bpmn:incoming>F1</bpmn:incoming>
        <bpmn:outgoing>F2</bpmn:outgoing>
      </bpmn:userTask>

      <bpmn:exclusiveGateway id="GW_KiemTra" name="Bác sĩ đúng chuyên môn?"  
  default="F_KhongDung">
        <bpmn:incoming>F2</bpmn:incoming>
        <bpmn:outgoing>F_Dung</bpmn:outgoing>
        <bpmn:outgoing>F_KhongDung</bpmn:outgoing>
      </bpmn:exclusiveGateway>

      <!-- Happy path -->
      <bpmn:userTask id="Task_BacSiXacNhan" name="Bác sĩ xác nhận lịch khám">
        <bpmn:extensionElements>
          <zeebe:assignmentDefinition assignee="doctor" />
        </bpmn:extensionElements>
        <bpmn:incoming>F_Dung</bpmn:incoming>
        <bpmn:outgoing>F4</bpmn:outgoing>
      </bpmn:userTask>

      <bpmn:endEvent id="End_OK" name="Lịch khám đã xác nhận">
        <bpmn:incoming>F4</bpmn:incoming>
      </bpmn:endEvent>

      <!-- Unhappy path -->
      <bpmn:userTask id="Task_ThongBaoDoi" name="[Test] Thông báo người dùng 
  cần đổi bác sĩ">
        <bpmn:extensionElements>
          <zeebe:assignmentDefinition assignee="receptionist" />
        </bpmn:extensionElements>
        <bpmn:incoming>F_KhongDung</bpmn:incoming>
        <bpmn:outgoing>F5</bpmn:outgoing>
      </bpmn:userTask>

      <bpmn:callActivity id="Call_ChonLai" name="Chọn lại bác sĩ phù hợp">   
        <bpmn:extensionElements>
          <zeebe:calledElement processId="chon-lai-bac-si"
  propagateAllChildVariables="false" />
          <zeebe:ioMapping>
            <zeebe:input source="=loaiThuCung" target="loaiThuCung" />       
            <zeebe:input source="=chuSoHuuId" target="chuSoHuuId" />
            <zeebe:input source="=bacSiId" target="bacSiCuId" />
            <zeebe:output source="=bacSiMoiId" target="bacSiMoiId" />        
            <zeebe:output source="=bacSiMoiTen" target="bacSiMoiTen" />      
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:incoming>F5</bpmn:incoming>
        <bpmn:outgoing>F6</bpmn:outgoing>
      </bpmn:callActivity>

      <bpmn:userTask id="Task_ThongBaoKetQua" name="[Test] Thông báo người   
  dùng kết quả đổi bác sĩ">
        <bpmn:extensionElements>
          <zeebe:assignmentDefinition assignee="receptionist" />
        </bpmn:extensionElements>
        <bpmn:incoming>F6</bpmn:incoming>
        <bpmn:outgoing>F7</bpmn:outgoing>
      </bpmn:userTask>

      <bpmn:endEvent id="End_DoiBacSi" name="Đã đổi bác sĩ và xác nhận lịch">
        <bpmn:incoming>F7</bpmn:incoming>
      </bpmn:endEvent>

      <bpmn:sequenceFlow id="F1" sourceRef="Start_1"
  targetRef="Task_TiepNhan" />
      <bpmn:sequenceFlow id="F2" sourceRef="Task_TiepNhan"
  targetRef="GW_KiemTra" />
      <bpmn:sequenceFlow id="F_Dung" name="Đúng chuyên môn"
  sourceRef="GW_KiemTra" targetRef="Task_BacSiXacNhan">
        <bpmn:conditionExpression>=dungChuyenMon =
  true</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="F_KhongDung" name="Không đúng chuyên môn"       
  sourceRef="GW_KiemTra" targetRef="Task_ThongBaoDoi" />
      <bpmn:sequenceFlow id="F4" sourceRef="Task_BacSiXacNhan"
  targetRef="End_OK" />
      <bpmn:sequenceFlow id="F5" sourceRef="Task_ThongBaoDoi"
  targetRef="Call_ChonLai" />
      <bpmn:sequenceFlow id="F6" sourceRef="Call_ChonLai"
  targetRef="Task_ThongBaoKetQua" />
      <bpmn:sequenceFlow id="F7" sourceRef="Task_ThongBaoKetQua"
  targetRef="End_DoiBacSi" />
    </bpmn:process>

    <bpmndi:BPMNDiagram id="BPMNDiagram_1">
      <bpmndi:BPMNPlane id="BPMNPlane_1"
  bpmnElement="dat-lich-kham-thu-cung">
        <!-- Happy path row y≈140 -->
        <bpmndi:BPMNShape id="Sh_Start" bpmnElement="Start_1">
          <dc:Bounds x="152" y="122" width="36" height="36" />
          <bpmndi:BPMNLabel><dc:Bounds x="126" y="165" width="88" height="27"
   /></bpmndi:BPMNLabel>
        </bpmndi:BPMNShape>
        <bpmndi:BPMNShape id="Sh_TiepNhan" bpmnElement="Task_TiepNhan">      
          <dc:Bounds x="250" y="100" width="190" height="80" />
        </bpmndi:BPMNShape>
        <bpmndi:BPMNShape id="Sh_GW" bpmnElement="GW_KiemTra"
  isMarkerVisible="true">
          <dc:Bounds x="495" y="115" width="50" height="50" />
          <bpmndi:BPMNLabel><dc:Bounds x="473" y="172" width="94" height="27"
   /></bpmndi:BPMNLabel>
        </bpmndi:BPMNShape>
        <bpmndi:BPMNShape id="Sh_BacSiXacNhan"
  bpmnElement="Task_BacSiXacNhan">
          <dc:Bounds x="607" y="100" width="180" height="80" />
        </bpmndi:BPMNShape>
        <bpmndi:BPMNShape id="Sh_EndOK" bpmnElement="End_OK">
          <dc:Bounds x="849" y="122" width="36" height="36" />
          <bpmndi:BPMNLabel><dc:Bounds x="823" y="165" width="88" height="27"
   /></bpmndi:BPMNLabel>
        </bpmndi:BPMNShape>

        <!-- Unhappy path row y≈330 -->
        <bpmndi:BPMNShape id="Sh_ThongBaoDoi" bpmnElement="Task_ThongBaoDoi">
          <dc:Bounds x="470" y="290" width="210" height="80" />
        </bpmndi:BPMNShape>
        <bpmndi:BPMNShape id="Sh_Call" bpmnElement="Call_ChonLai">
          <dc:Bounds x="742" y="290" width="200" height="80" />
        </bpmndi:BPMNShape>
        <bpmndi:BPMNShape id="Sh_ThongBaoKetQua"
  bpmnElement="Task_ThongBaoKetQua">
          <dc:Bounds x="1004" y="290" width="210" height="80" />
        </bpmndi:BPMNShape>
        <bpmndi:BPMNShape id="Sh_EndDoi" bpmnElement="End_DoiBacSi">
          <dc:Bounds x="1276" y="312" width="36" height="36" />
          <bpmndi:BPMNLabel><dc:Bounds x="1249" y="355" width="90"
  height="27" /></bpmndi:BPMNLabel>
        </bpmndi:BPMNShape>

        <!-- Edges -->
        <bpmndi:BPMNEdge id="Ed_F1" bpmnElement="F1">
          <di:waypoint x="188" y="140" /><di:waypoint x="250" y="140" />     
        </bpmndi:BPMNEdge>
        <bpmndi:BPMNEdge id="Ed_F2" bpmnElement="F2">
          <di:waypoint x="440" y="140" /><di:waypoint x="495" y="140" />     
        </bpmndi:BPMNEdge>
        <bpmndi:BPMNEdge id="Ed_F_Dung" bpmnElement="F_Dung">
          <di:waypoint x="545" y="140" /><di:waypoint x="607" y="140" />     
          <bpmndi:BPMNLabel><dc:Bounds x="550" y="122" width="52" height="14"
   /></bpmndi:BPMNLabel>
        </bpmndi:BPMNEdge>
        <bpmndi:BPMNEdge id="Ed_F_KhongDung" bpmnElement="F_KhongDung">      
          <di:waypoint x="520" y="165" /><di:waypoint x="520" y="330"        
  /><di:waypoint x="470" y="330" />
          <bpmndi:BPMNLabel><dc:Bounds x="430" y="238" width="76" height="27"
   /></bpmndi:BPMNLabel>
        </bpmndi:BPMNEdge>
        <bpmndi:BPMNEdge id="Ed_F4" bpmnElement="F4">
          <di:waypoint x="787" y="140" /><di:waypoint x="849" y="140" />     
        </bpmndi:BPMNEdge>
        <bpmndi:BPMNEdge id="Ed_F5" bpmnElement="F5">
          <di:waypoint x="680" y="330" /><di:waypoint x="742" y="330" />     
        </bpmndi:BPMNEdge>
        <bpmndi:BPMNEdge id="Ed_F6" bpmnElement="F6">
          <di:waypoint x="942" y="330" /><di:waypoint x="1004" y="330" />    
        </bpmndi:BPMNEdge>
        <bpmndi:BPMNEdge id="Ed_F7" bpmnElement="F7">
          <di:waypoint x="1214" y="330" /><di:waypoint x="1276" y="330" />   
        </bpmndi:BPMNEdge>
      </bpmndi:BPMNPlane>
    </bpmndi:BPMNDiagram>
  </bpmn:definitions>