flowchart TB
  subgraph products_module["products-service"]
    direction TB
    subgraph products_base["com.mss301.petclinic.products"]
      direction TB
      config["config"]
      controller["controller"]
      subgraph dto_pkg["dto"]
        direction LR
        req["req"]
        res["res"]
      end
      exception["exception"]
      model["model"]
      repository["repository"]
      subgraph service_pkg["service"]
        impl["impl"]
      end
    end
  end

  subgraph shared_deps["shared libraries"]
    direction LR
    common_web["common-web"]
    common_jpa["common-jpa"]
    common_security["common-security"]
  end

  controller -.-> service_pkg
  controller -.-> dto_pkg
  impl -.-> repository
  impl -.-> exception
  repository -.-> model
  dto_pkg -.-> model
  products_base -.->|Gradle| shared_deps
