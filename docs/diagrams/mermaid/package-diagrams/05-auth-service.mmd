      direction TB
      config["config"]
      controller["controller"]
      subgraph dto_pkg["dto"]
        direction LR
        req["req"]
        res["res"]
      end
      events["events"]
      exception["exception"]
      model["model"]
      repository["repository"]
      security["security"]
      subgraph service_pkg["service"]
        impl["impl"]
      end
